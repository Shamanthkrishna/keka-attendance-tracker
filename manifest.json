{
  "manifest_version": 3,
  "name": "AT2 - Advanced Attendance Tracker",
  "version": "2.1",
  "description": "Advanced attendance tracker with real-time updates, notifications, streaks, and comprehensive workday management for Keka HRM.",
  "permissions": ["scripting", "tabs", "storage", "notifications", "alarms", "activeTab"],
  "host_permissions": ["*://*.keka.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup_simple.html",
    "default_title": "AT2 - Advanced Attendance Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background_simple.js"
  }
}
